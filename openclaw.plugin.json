      "telegramBotToken": { "type": "string" },
      "databasePath": { "type": "string" },
      "pollEnabled": { "type": "boolean" }
    }
  },
  "uiHints": {
    "seoulApiKey": { "label": "Seoul Bus API Key", "sensitive": true },
    "gyeonggiApiKey": { "label": "Gyeonggi Bus API Key", "sensitive": true },
    "telegramBotToken": { "label": "Telegram Bot Token", "sensitive": true }
  }
}
